{
  "name": "Running Coach Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [8080],
  "postCreateCommand": "pip install -r backend/requirements.txt && npm install -g serve",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ritwickdey.LiveServer"]
    }
  },
  "portsAttributes": {
    "8080": { "label": "Running Coach UI", "onAutoForward": "openBrowser" }
  }
}
